generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// JSON SCHEMA VERSIONING STRATEGY
// ---------------------------------------------------------------------------
// Schema versioning is embedded within JSON documents (e.g., {"schemaVersion": 2})
// rather than as separate database columns. This allows:
//
// 1. Schema version = "How should this JSON be interpreted?"
// 2. Content version = "How many times was this content edited?"
//
// VERSIONED JSON (author-controlled, evolves independently):
// - LearningAction.content (crosses authoring <-> runtime boundary)
// - PracticeActivity.content (crosses authoring <-> runtime boundary)
// - InterviewPhaseTemplate.evaluationDimensions (template structure)
// - InterviewPhaseTemplate.goals (template structure)
//
// NOT VERSIONED (snapshots, implementation details):
// - codeState, whiteboardState (frozen application state)
// - candidatePersona (configuration snapshot)
// - metadata (arbitrary metadata)
//
// ADAPTER PATTERN (not migrations):
// When schema evolves, add adapters to read old versions instead of
// migrating historical data. Services only deal with canonical domain model.
//
// VALIDATION ON WRITE:
// All AI-generated JSON is validated against schema before persistence
// using JSON Schema/Zod to ensure contract compliance.
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interviews              Interview[]
  masteries               ConceptMastery[]
  learningAttempts        UserLearningAttempt[]
  practiceAttempts        PracticeAttempt[]
  practiceRecommendations PracticeRecommendation[]
  learningRecommendations LearningRecommendation[]
}

model Transcript {
  id          String   @id @default(cuid())

  slug        String   @unique

  title       String

  category    String

  difficulty  String

  company     String?

  interviewer String?

  candidate   String?

  duration    Int?

  summary     String?

  transcript  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ---------------------------------------------------------------------------
// Dynamic interview templates. Adding a new interview type (DSA, Behavioral,
// Concurrency, ...) is now a data-seed operation: insert one InterviewTemplate
// row, its InterviewPhaseTemplate rows (in order), and its RubricTemplate
// rows. No enum change, no migration, no new resolver branch, no new profile
// file.
// ---------------------------------------------------------------------------
model InterviewTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // NEW — tells frontend which node/preset set to load ("hld" | "lld" | null = no whiteboard)
  whiteboardPreset String?

  phases     InterviewPhaseTemplate[]
  rubrics    RubricTemplate[]
  interviews Interview[]
}
model InterviewPhaseTemplate {
  id         String            @id @default(cuid())
  templateId String
  template   InterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  phaseKey String
  order    Int

  goals                Json // Schema version embedded: {"schemaVersion": 1, ...}
  evaluationDimensions Json // Schema version embedded: {"schemaVersion": 1, ...}
  targetDurationRatio  Float
  transitionThreshold  Float
  instructions         String

  // NEW — per-phase gate, not per-template. HLD's "requirements" phase should
  // NOT show whiteboard even though the template supports it.
  showWhiteboard Boolean @default(false)

  // NEW — separate dimension set for reverse mode
  reverseEvaluationDimensions Json @default("[]") // Schema version embedded

  @@unique([templateId, phaseKey])
  @@index([templateId])
}

model RubricTemplate {
  id         String            @id @default(cuid())
  templateId String
  template   InterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  dimension String // must match a value used in some phase's evaluationDimensions
  content   String
  weight    Float  @default(1.0)

  @@unique([templateId, dimension])
}

model Interview {
  id            String          @id @default(cuid())
  userId        String
  templateId    String
  difficulty    Difficulty
  duration      Int
  company       String
  status        InterviewStatus
  currentPhase   String
  phaseStartedAt DateTime?
  summary        String          @default("Interview has not started yet.")
  promptVersion  String          @default("v1")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  problemId String

  // NEW — interview mode
  mode             InterviewMode @default(CANDIDATE)
  candidatePersona Json? // Configuration snapshot, no versioning needed

  // NEW — code editor state (deprioritized, not wired into prompts/evaluator yet)
  codeState Json? // Frozen application state, no versioning needed

  // NEW — metadata for storing error states and other runtime information
  metadata Json? // Arbitrary metadata, no versioning needed

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   InterviewTemplate @relation(fields: [templateId], references: [id])
  evaluation Evaluation?
  problem    Problem           @relation(fields: [problemId], references: [id])
  transcript Message[]
  whiteboardState Json? // Frozen application state, no versioning needed
  @@index([templateId])
  @@index([userId])
}

model Message {
  id          String      @id @default(cuid())
  interviewId String
  role        MessageRole
  content     String
  metadata    Json? // Arbitrary metadata, no versioning needed

  // NEW — written at persist time, not reconstructed later
  elapsedSeconds Int     @default(0)
  phase          String?

  createdAt   DateTime    @default(now())
  interview   Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  evidenceItems EvidenceItem[]

  @@index([interviewId])
}

model Problem {
  id   String @id @default(uuid())
  slug             String                @unique
  title            String
  description      String?
  category         ProblemCategory
  difficulty       Difficulty
  interviewCount   Int                   @default(0)
  cruxOfProblem    String?
  estimatedMinutes Int?
  interviewType    String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  interviews       Interview[]
  experiences      InterviewExperience[]
  companies        ProblemCompany[]
  tags             ProblemTag[]
  concepts         ProblemConcept[]
}

model Company {
  id                   String                @id @default(cuid())
  name                 String                @unique
  interviewExperiences InterviewExperience[]
  problems             ProblemCompany[]
}

model ProblemCompany {
  problemId String
  companyId String
  frequency Int?
  lastSeen  DateTime?
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  problem   Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([problemId, companyId])
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  problems ProblemTag[]
}

model ProblemTag {
  problemId String
  tagId     String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([problemId, tagId])
}

model InterviewExperience {
  id        String           @id @default(cuid())
  problemId String
  companyId String
  role      String?
  level     String?
  year      Int?
  source    ExperienceSource
  url       String
  notes     String?
  createdAt DateTime         @default(now())
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  problem   Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Evidence-based evaluation. dimensionScores/evidence stay as denormalized
// Json — they're a read-optimized cache for the report page. EvidenceItem
// below is the normalized, queryable source of truth that Mastery reads from.
// ---------------------------------------------------------------------------

model Evaluation {
  id          String @id @default(cuid())
  interviewId String @unique

  overallScore Int

  // DimensionScore[]: { dimension, score, summary, evidence: EvidenceItem[] }
  // TODO: Normalize to EvaluationDimensionScore table for analytics
  dimensionScores Json // Schema version embedded: {"schemaVersion": 1, ...}

  // Flattened EvidenceItem[]: { dimension, messageId, timestampSeconds, quote, comment }
  // CACHE: EvidenceItem table is source of truth. This is denormalized for report performance.
  evidence Json // Schema version embedded: {"schemaVersion": 1, ...}

  feedback  String
  metadata  Json? // Arbitrary metadata, no versioning needed
  createdAt DateTime @default(now())

  interview     Interview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  evidenceItems EvidenceItem[]
}

// ---------------------------------------------------------------------------
// Skill Intelligence Layer: Interview -> Evidence -> Concepts -> Mastery ->
// Recommendations. EvidenceItem/EvidenceConcept are written alongside the
// Evaluation.evidence Json blob (see EvaluationService); ConceptMastery is
// recomputed from them after every evaluation (see MasteryService).
// ---------------------------------------------------------------------------

model Concept {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  category    String

  parentId String?
  parent   Concept?  @relation("ConceptHierarchy", fields: [parentId], references: [id])
  children Concept[] @relation("ConceptHierarchy")

  createdAt DateTime @default(now())

  evidenceLinks EvidenceConcept[]
  masteries     ConceptMastery[]
  problems      ProblemConcept[]

  learningSegments LearningSegmentConcept[]
  learningActionConcepts LearningActionConcept[]
  learningRecommendations LearningRecommendation[]
  practiceActivityConcepts PracticeActivityConcept[]
  practiceRecommendationItems PracticeRecommendationItem[]
}

model EvidenceItem {
  id               String       @id @default(cuid())
  evaluationId     String
  evaluation       Evaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  messageId        String
  message          Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  dimension        String
  timestampSeconds Int
  quote            String
  comment          String
  type             EvidenceType
  normalizedScore  Float         @default(0)
  createdAt        DateTime      @default(now())

  concepts EvidenceConcept[]

  @@index([evaluationId])
  @@index([messageId])
}

model EvidenceConcept {
  evidenceItemId String
  conceptId      String
  weight         Float @default(1.0) // how strongly this item demonstrates the concept, 0-1

  evidenceItem EvidenceItem @relation(fields: [evidenceItemId], references: [id], onDelete: Cascade)
  concept      Concept      @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([evidenceItemId, conceptId])
  @@index([conceptId])
}

model ConceptMastery {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  conceptId String
  concept   Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  score              Float     @default(0) // 0-1 rolling estimate
  confidence         Float     @default(0) // 0-1, low until enough evidence accumulates
  sampleCount        Int       @default(0)
  lastDemonstratedAt DateTime?
  updatedAt          DateTime  @updatedAt

  @@unique([userId, conceptId])
  @@index([userId])
}

model ProblemConcept {
  problemId String
  conceptId String
  weight    Float @default(1.0) // how heavily this problem exercises the concept

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([problemId, conceptId])
}


model LearningScenario {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?

  // e.g. "Design a Payment System"
  context Json? // Arbitrary metadata, no versioning needed

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments LearningSegment[]
}

model LearningSegment {
  id         String @id @default(cuid())
  scenarioId String

  scenario LearningScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  order        Int
  conversation Json // Schema version embedded: {"schemaVersion": 1, ...}
  takeaway     String?

  actions  LearningAction[]
  concepts LearningSegmentConcept[]

  @@unique([scenarioId, order])
  @@index([scenarioId])
}

model LearningSegmentConcept {
  scenarioId String
  segmentId  String
  conceptId  String

  weight Float @default(1.0)

  segment LearningSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([scenarioId, segmentId, conceptId])
  @@index([conceptId])
}

model LearningAction {
  id        String @id @default(cuid())
  segmentId String

  segment LearningSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  type LearningActionType

  title        String
  instructions String?
  content      Json // Schema version embedded: {"schemaVersion": 1, ...}

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts UserLearningAttempt[]
  concepts LearningActionConcept[]
  recommendationItems LearningRecommendation[]

  @@index([segmentId])
  @@index([type, isActive])
}

model LearningActionConcept {
  actionId  String
  conceptId String

  weight Float @default(1.0)

  action LearningAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([actionId, conceptId])
  @@index([conceptId])
}

model UserLearningAttempt {
  id       String @id @default(cuid())
  userId   String
  actionId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  action LearningAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  status LearningAttemptStatus @default(STARTED)

  response        Json? // Schema version embedded if response format evolves

  score    Float?
  feedback String?

  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId, completedAt])
  @@index([userId, actionId])
  @@index([actionId])
}

model LearningRecommendation {
  id       String @id @default(cuid())
  userId   String
  actionId String
  conceptId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  action LearningAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  masteryScore      Float
  masteryConfidence Float

  reason String

  createdAt DateTime @default(now())
  dismissedAt DateTime?
  consumedAt  DateTime?

  @@index([userId, createdAt])
  @@index([userId, consumedAt])
}

enum LearningAttemptStatus {
  STARTED
  COMPLETED
  ABANDONED
}

enum LearningActionType {
  OBSERVE
  JUDGE
  FIX
  PREDICT
  COMPARE
}

enum ProblemCategory {
  SYSTEM_DESIGN
  LOW_LEVEL_DESIGN
  DATABASES
  BACKEND
  DISTRIBUTED_SYSTEMS
  JAVA
  KAFKA
  REDIS
  OPERATING_SYSTEMS
  NETWORKING
}

enum ExperienceSource {
  LEETCODE
  ENGINEERBOOGIE
  GLASSDOOR
  USER_SUBMISSION
}

enum InterviewMode {
  CANDIDATE
  REVERSE
}

enum InterviewStatus {
  SETUP
  IN_PROGRESS
  COMPLETED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MessageRole {
  assistant
  user
}

enum EvidenceType {
  STRENGTH
  WEAKNESS
}

model PracticeActivity {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String?

  type PracticeActivityType

  difficulty Difficulty

  estimatedMinutes Int?

  content        Json // Schema version embedded: {"schemaVersion": 1, ...}

  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  concepts PracticeActivityConcept[]
  attempts PracticeAttempt[]

  recommendationItems PracticeRecommendationItem[]

  @@index([type, isPublished])
  @@index([difficulty, isPublished])
}

model PracticeActivityConcept {
  activityId String
  conceptId  String

  weight Float @default(1.0)

  activity PracticeActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@id([activityId, conceptId])
  @@index([conceptId])
}

model PracticeAttempt {
  id         String @id @default(cuid())
  userId     String
  activityId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  activity PracticeActivity @relation(fields: [activityId], references: [id], onDelete: Restrict)

  status PracticeAttemptStatus @default(STARTED)

  response        Json? // Schema version embedded if response format evolves

  score    Float?
  feedback String?

  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId, completedAt])
  @@index([userId, activityId])
}

model PracticeRecommendation {
  id     String @id @default(cuid())
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason String?

  createdAt DateTime @default(now())
  expiresAt DateTime?

  items PracticeRecommendationItem[]

  @@index([userId, createdAt])
}

model PracticeRecommendationItem {
  recommendationId String
  activityId       String

  rank Int

  targetConceptId String?

  recommendation PracticeRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  activity PracticeActivity @relation(fields: [activityId], references: [id], onDelete: Restrict)

  targetConcept Concept? @relation(fields: [targetConceptId], references: [id], onDelete: SetNull)

  reason String?

  @@id([recommendationId, activityId])
  @@index([activityId])
  @@index([targetConceptId])
}

enum PracticeActivityType {
  MOCK_INTERVIEW
  BUG_HUNT
  JUDGE
  FIX
  PREDICT
  COMPARE
}

enum PracticeAttemptStatus {
  STARTED
  COMPLETED
  ABANDONED
}